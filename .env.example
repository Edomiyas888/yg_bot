# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username_here
HAPPY_BOT_TOKEN=your_happy_bot_token_here

# Game URL (Telegram Mini App / hosted web app)
GAME_URL=https://ygbingo.netlify.app

# Optional: Webhook URL (if using webhooks)
WEBHOOK_URL=https://your-domain.com/webhook

# Optional: Database configuration
DATABASE_URL=

# Optional: API Keys
API_KEY=

# Firebase Admin SDK — required for registration
# RECOMMENDED (Northflank): paste the entire service-account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"bgeno2-fa38b","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@bgeno2-fa38b.iam.gserviceaccount.com","client_id":"..."}

# Or individual fields (must be a NEW valid key for project bgeno2-fa38b)
FIREBASE_PROJECT_ID=bgeno2-fa38b
FIREBASE_DATABASE_URL=https://bgeno2-fa38b-default-rtdb.firebaseio.com/
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@bgeno2-fa38b.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=
FIREBASE_CLIENT_CERT_URL=

# Optional: Proxy Configuration
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,*.googleapis.com,*.firebaseio.com
